  published
  archived
}

enum AssignmentStatus {
  pending
  confirmed
  declined
  swapped
}

enum SwapStatus {
  pending
  accepted
  rejected
  cancelled
}

enum VolunteerMinistryRole {
  leader
  volunteer
}

enum CelebrationType {
