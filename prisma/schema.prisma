  published
  finalized
  cancelled
}

enum ResponsibleType {
  person
  ministry
  free_text
}

// =============================================================================
// GRUPO 9 — WAITLIST (lead capture pré-lançamento)
// Exceção ao modelo multi-tenant: lead ainda não é cliente
// =============================================================================

model WaitlistSubscriber {
  id           String            @id @default(uuid())
  email        String            @unique
  pastor_name  String
  church_name  String?
  city         String?
  state        String?
  size_range   WaitlistSizeRange
  lgpd_consent Boolean           @default(false)
  source       String?
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  status       WaitlistStatus    @default(pending)
  notes        String?
  tenant_id    String?
  ip           String?
  user_agent   String?
  created_at   DateTime          @default(now())
  contacted_at DateTime?
  activated_at DateTime?

  @@index([status])
  @@index([created_at(sort: Desc)])
  @@map("waitlist_subscribers")
}

enum WaitlistSizeRange {
  ate_50
  ate_150
  ate_300
  acima_300
}

// =============================================================================
// GRUPO 10 — QR TOKENS (cadastro público de visitante)
// =============================================================================

model QrToken {
  id              String      @id @default(uuid())
  tenant_id       String
  congregation_id String
  token           String      @unique @default(uuid())
  origin          VisitOrigin
  small_group_id  String?
  label           String?
  is_active       Boolean     @default(true)
  scan_count      Int         @default(0)
  created_by      String
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tenant_id, congregation_id])
  @@map("qr_tokens")
}

enum WaitlistStatus {
  pending
  contacted
  activated
  declined
}

// =============================================================================
// GRUPO 11 — JOBS (export / import)
// =============================================================================

enum ExportJobType {
  csv
  ofx
  pdf
  zip
  sped
  dre
}

enum JobStatus {
  pending
  processing
  done
  error
}

model ExportJob {
  id              String        @id @default(uuid())
  tenant_id       String
  congregation_id String
  type            ExportJobType
  status          JobStatus     @default(pending)
  period_start    DateTime
  period_end      DateTime
  file_url        String?
  error_message   String?
  created_by      String
  created_at      DateTime      @default(now())

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, congregation_id])
  @@index([tenant_id, created_at(sort: Desc)])
  @@map("export_jobs")
}

model ImportJob {
  id              String    @id @default(uuid())
  tenant_id       String
  congregation_id String
  type            String
  status          JobStatus @default(pending)
  total_rows      Int       @default(0)
  imported        Int       @default(0)
  skipped         Int       @default(0)
  errors          Json      @default("[]")
  created_by      String
  created_at      DateTime  @default(now())

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, congregation_id])
  @@index([tenant_id, created_at(sort: Desc)])
  @@map("import_jobs")
}
