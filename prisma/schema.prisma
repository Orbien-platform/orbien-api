// =============================================================================
// ORBIEN — Prisma Schema v1.0
// SaaS white-label de gestão de igrejas | Multi-tenant 3 níveis
// Stack: Prisma + PostgreSQL (Supabase) + NestJS
// Multi-tenancy: shared tables com tenant_id + congregation_id
// RLS: aplicado via migration SQL separada (001_rls_setup.sql)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// GRUPO 1 — FUNDAÇÃO
// =============================================================================

model Tenant {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  email      String?
  phone      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  congregations           Congregation[]
  brandingConfig          BrandingConfig?
  tenantPlan              TenantPlan?
  userAccounts            UserAccount[]
  roleAssignments         RoleAssignment[]
  persons                 Person[]
  households              Household[]
  classificationHistories ClassificationHistory[]
  visitRecords            VisitRecord[]
  consentRecords          ConsentRecord[]
  personTags              PersonTag[]
  smallGroups             SmallGroup[]
  groupTypes              GroupType[]
  groupMemberships        GroupMembership[]
  groupMeetings           GroupMeeting[]
  attendanceRecords       AttendanceRecord[]
  prayerRequests          PrayerRequest[]
  studyMaterials          StudyMaterial[]
  materialOpenRecords     MaterialOpenRecord[]
  groupMeetingMaterials   GroupMeetingMaterial[]
  financialCategories     FinancialCategory[]
  costCenters             CostCenter[]
  financialTransactions   FinancialTransaction[]
  transactionAttachments  TransactionAttachment[]
  recurringRules          RecurringRule[]
  pixPayments             PixPayment[]
  donationReceipts        DonationReceipt[]
  contentPosts            ContentPost[]
  audienceSegments        AudienceSegment[]
  notificationDispatches  NotificationDispatch[]
  ministries              Ministry[]
  volunteerProfiles       VolunteerProfile[]
  volunteerMinistries     VolunteerMinistry[]
  serviceSchedules        ServiceSchedule[]
  scheduleSlots           ScheduleSlot[]
  scheduleAssignments     ScheduleAssignment[]
  volunteerSwapRequests   VolunteerSwapRequest[]
  assignments             Assignment[]
  celebrations            Celebration[]
  celebrationInstances    CelebrationInstance[]
  serviceOrders           ServiceOrder[]
  serviceOrderItems       ServiceOrderItem[]
  setlists                Setlist[]
  setlistSongs            SetlistSong[]
  auditLogs               AuditLog[]
  qrTokens                QrToken[]
  exportJobs              ExportJob[]
  importJobs              ImportJob[]

  @@index([id])
  @@map("tenants")
}

model Congregation {
  id            String   @id @default(uuid())
  tenant_id     String
  name          String
  address       String?
  timezone      String   @default("America/Sao_Paulo")
  email         String?
  phone         String?
  logo_url      String?
  primary_color String?
  app_name      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  userAccounts            UserAccount[]
  roleAssignments         RoleAssignment[]
  persons                 Person[]
  households              Household[]
  classificationHistories ClassificationHistory[]
  visitRecords            VisitRecord[]
  consentRecords          ConsentRecord[]
  personTags              PersonTag[]
  smallGroups             SmallGroup[]
  groupTypes              GroupType[]
  groupMemberships        GroupMembership[]
  groupMeetings           GroupMeeting[]
  attendanceRecords       AttendanceRecord[]
  prayerRequests          PrayerRequest[]
  studyMaterials          StudyMaterial[]
  financialCategories     FinancialCategory[]
  costCenters             CostCenter[]
  financialTransactions   FinancialTransaction[]
  recurringRules          RecurringRule[]
  pixPayments             PixPayment[]
  contentPosts            ContentPost[]
  audienceSegments        AudienceSegment[]
  notificationDispatches  NotificationDispatch[]
  ministries              Ministry[]
  volunteerProfiles       VolunteerProfile[]
  volunteerMinistries     VolunteerMinistry[]
  serviceSchedules        ServiceSchedule[]
  scheduleSlots           ScheduleSlot[]
  scheduleAssignments     ScheduleAssignment[]
  volunteerSwapRequests   VolunteerSwapRequest[]
  assignments             Assignment[]
  celebrations            Celebration[]
  celebrationInstances    CelebrationInstance[]
  serviceOrders           ServiceOrder[]
  serviceOrderItems       ServiceOrderItem[]
  setlists                Setlist[]
  setlistSongs            SetlistSong[]
  materialOpenRecords     MaterialOpenRecord[]
  groupMeetingMaterials   GroupMeetingMaterial[]
  qrTokens                QrToken[]
  exportJobs              ExportJob[]
  importJobs              ImportJob[]

  @@index([tenant_id, id])
  @@map("congregations")
}

model BrandingConfig {
  id              String   @id @default(uuid())
  tenant_id       String   @unique
  primary_color   String?
  secondary_color String?
  logo_url        String?
  app_name        String?
  splash_url      String?
  pix_key         String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("branding_configs")
}

model TenantPlan {
  id                     String     @id @default(uuid())
  tenant_id              String     @unique
  plan                   PlanType
  status                 PlanStatus
  trial_ends_at          DateTime?
  current_period_ends_at DateTime?
  created_at             DateTime   @default(now())
  updated_at             DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("tenant_plans")
}

// =============================================================================
// GRUPO 2 — AUTH
// =============================================================================

model UserAccount {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  person_id       String?
  email           String
  password_hash   String
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person?      @relation(fields: [person_id], references: [id], onDelete: SetNull)

  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  roleAssignments         RoleAssignment[]
  classificationHistories ClassificationHistory[]
  createdTransactions     FinancialTransaction[]
  uploadedAttachments     TransactionAttachment[]
  createdPosts            ContentPost[]
  actorAuditLogs          AuditLog[]              @relation("AuditActorUser")

  @@unique([tenant_id, email])
  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("user_accounts")
}

/// Tabela de referência global — sem tenant_id
model Role {
  code        String  @id
  name        String
  description String?

  roleAssignments RoleAssignment[]

  @@map("roles")
}

model RoleAssignment {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  user_account_id String
  role_code       String
  small_group_id  String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  userAccount  UserAccount  @relation(fields: [user_account_id], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [role_code], references: [code], onDelete: Restrict)
  smallGroup   SmallGroup?  @relation(fields: [small_group_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, user_account_id])
  @@map("role_assignments")
}

model RefreshToken {
  id              String    @id @default(uuid())
  user_account_id String
  token_hash      String    @unique
  expires_at      DateTime
  revoked_at      DateTime?
  replaced_by_id  String?
  created_at      DateTime  @default(now())

  userAccount  UserAccount    @relation(fields: [user_account_id], references: [id], onDelete: Cascade)
  replacedBy   RefreshToken?  @relation("TokenRotation", fields: [replaced_by_id], references: [id])
  replacements RefreshToken[] @relation("TokenRotation")

  @@index([user_account_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user UserAccount @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

// =============================================================================
// GRUPO 3 — PESSOAS
// =============================================================================

model Person {
  id                   String               @id @default(uuid())
  tenant_id            String
  congregation_id      String
  full_name            String
  phone                String?
  email                String?
  birth_date           DateTime?
  gender               Gender?
  marital_status       MaritalStatus?
  profession           String?
  address_street       String?
  address_number       String?
  address_complement   String?
  address_neighborhood String?
  address_city         String?
  address_state        String?
  address_zip          String?
  photo_url            String?
  baptism_date         DateTime?
  membership_date      DateTime?
  former_denomination  String?
  origin_congregation  String?
  classification       PersonClassification @default(visitor)
  household_id         String?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  household    Household?   @relation(fields: [household_id], references: [id], onDelete: SetNull)

  userAccounts            UserAccount[]
  householdMemberships    HouseholdMember[]
  classificationHistories ClassificationHistory[]
  visitRecords            VisitRecord[]
  consentRecords          ConsentRecord[]
  personTags              PersonTag[]
  groupMemberships        GroupMembership[]
  attendanceRecords       AttendanceRecord[]
  prayerRequests          PrayerRequest[]
  materialOpenRecords     MaterialOpenRecord[]
  ledSmallGroups          SmallGroup[]            @relation("GroupLeader")
  donorTransactions       FinancialTransaction[]  @relation("TransactionDonor")
  donationReceipts        DonationReceipt[]
  pixDonations            PixPayment[]            @relation("PixDonor")
  volunteerProfile        VolunteerProfile?
  assignments             Assignment[]
  serviceOrderItems       ServiceOrderItem[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, phone])
  @@map("persons")
}

model Household {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  name            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  members HouseholdMember[]
  persons Person[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("households")
}

model HouseholdMember {
  id           String              @id @default(uuid())
  household_id String
  person_id    String
  role         HouseholdMemberRole
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt

  household Household @relation(fields: [household_id], references: [id], onDelete: Cascade)
  person    Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@unique([household_id, person_id])
  @@index([household_id])
  @@index([person_id])
  @@map("household_members")
}

model ClassificationHistory {
  id                  String               @id @default(uuid())
  tenant_id           String
  congregation_id     String
  person_id           String
  from_classification PersonClassification
  to_classification   PersonClassification
  changed_by_user_id  String
  reason              String?
  changed_at          DateTime             @default(now())
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)
  changedBy    UserAccount  @relation(fields: [changed_by_user_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, person_id])
  @@map("classification_histories")
}

model VisitRecord {
  id              String      @id @default(uuid())
  tenant_id       String
  congregation_id String
  person_id       String
  origin          VisitOrigin
  small_group_id  String?
  visited_at      DateTime
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)
  smallGroup   SmallGroup?  @relation(fields: [small_group_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, person_id])
  @@index([tenant_id, person_id, visited_at])
  @@map("visit_records")
}

model ConsentRecord {
  id                String    @id @default(uuid())
  tenant_id         String
  congregation_id   String
  person_id         String
  version           String
  consented_at      DateTime
  ip                String?
  user_agent        String?
  origin            String?
  revoked_at        DateTime?
  revocation_reason String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, person_id])
  @@map("consent_records")
}

model PersonTag {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  person_id       String
  tag             String
  is_system_tag   Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, congregation_id, person_id, tag])
  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("person_tags")
}

// =============================================================================
// GRUPO 4 — PEQUENOS GRUPOS
// =============================================================================

model SmallGroup {
  id                 String   @id @default(uuid())
  tenant_id          String
  congregation_id    String
  name               String
  group_type_id      String
  parent_group_id    String?
  leader_person_id   String
  address            String?
  lat                Decimal? @db.Decimal(10, 7)
  lng                Decimal? @db.Decimal(10, 7)
  meeting_time       String?
  recurrence         String?
  is_public          Boolean  @default(false)
  public_description String?
  public_photo_url   String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  groupType    GroupType    @relation(fields: [group_type_id], references: [id], onDelete: Restrict)
  leader       Person       @relation("GroupLeader", fields: [leader_person_id], references: [id], onDelete: Restrict)
  parentGroup  SmallGroup?  @relation("GroupHierarchy", fields: [parent_group_id], references: [id], onDelete: SetNull)
  childGroups  SmallGroup[] @relation("GroupHierarchy")

  memberships     GroupMembership[]
  meetings        GroupMeeting[]
  prayerRequests  PrayerRequest[]
  materialTargets MaterialTarget[]
  visitRecords    VisitRecord[]
  roleAssignments RoleAssignment[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([group_type_id])
  @@map("small_groups")
}

model GroupType {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  name            String
  color           String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  smallGroups  SmallGroup[]

  @@index([tenant_id, congregation_id])
  @@map("group_types")
}

model GroupMembership {
  id              String          @id @default(uuid())
  tenant_id       String
  congregation_id String
  small_group_id  String
  person_id       String
  role            GroupMemberRole
  joined_at       DateTime        @default(now())
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  smallGroup   SmallGroup   @relation(fields: [small_group_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@unique([small_group_id, person_id])
  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([small_group_id])
  @@map("group_memberships")
}

model GroupMeeting {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  small_group_id  String
  occurred_at     DateTime
  topic           String?
  observations    String?
  offering_amount Decimal? @db.Decimal(12, 2)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  smallGroup   SmallGroup   @relation(fields: [small_group_id], references: [id], onDelete: Cascade)

  attendanceRecords AttendanceRecord[]
  materials         GroupMeetingMaterial[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([small_group_id])
  @@map("group_meetings")
}

model AttendanceRecord {
  id               String   @id @default(uuid())
  tenant_id        String
  congregation_id  String
  group_meeting_id String
  person_id        String
  checked_in_at    DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  groupMeeting GroupMeeting @relation(fields: [group_meeting_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@unique([group_meeting_id, person_id])
  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([group_meeting_id])
  @@map("attendance_records")
}

model PrayerRequest {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  small_group_id  String
  person_id       String
  content         String
  is_anonymous    Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  smallGroup   SmallGroup   @relation(fields: [small_group_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([small_group_id])
  @@map("prayer_requests")
}

model StudyMaterial {
  id              String              @id @default(uuid())
  tenant_id       String
  congregation_id String
  title           String
  description     String?
  author          String?
  source_type     StudyMaterialSource
  file_url        String?
  rich_content    String?
  publish_at      DateTime
  expires_at      DateTime?
  notified_at     DateTime?
  version         Int                 @default(1)
  tags            String[]
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  materialTargets  MaterialTarget[]
  openRecords      MaterialOpenRecord[]
  meetingMaterials GroupMeetingMaterial[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([publish_at])
  @@map("study_materials")
}

/// Tabela de junção: material → grupos-alvo
model MaterialTarget {
  study_material_id String
  small_group_id    String

  studyMaterial StudyMaterial @relation(fields: [study_material_id], references: [id], onDelete: Cascade)
  smallGroup    SmallGroup    @relation(fields: [small_group_id], references: [id], onDelete: Cascade)

  @@id([study_material_id, small_group_id])
  @@index([small_group_id])
  @@map("material_targets")
}

model MaterialOpenRecord {
  id                String   @id @default(uuid())
  tenant_id         String
  congregation_id   String
  study_material_id String
  person_id         String
  opened_at         DateTime @default(now())
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation  Congregation  @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  studyMaterial StudyMaterial @relation(fields: [study_material_id], references: [id], onDelete: Cascade)
  person        Person        @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, study_material_id])
  @@index([tenant_id, congregation_id])
  @@index([person_id])
  @@map("material_open_records")
}

model GroupMeetingMaterial {
  id              String             @id @default(uuid())
  tenant_id       String
  congregation_id String
  meeting_id      String
  material_id     String
  visibility      MaterialVisibility @default(all)
  created_at      DateTime           @default(now())

  tenant       Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation  @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  meeting      GroupMeeting  @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  material     StudyMaterial @relation(fields: [material_id], references: [id], onDelete: Cascade)

  @@unique([meeting_id, material_id])
  @@index([tenant_id, congregation_id])
  @@index([material_id])
  @@map("group_meeting_materials")
}

// =============================================================================
// GRUPO 5 — FINANCEIRO
// =============================================================================

model FinancialCategory {
  id              String                @id @default(uuid())
  tenant_id       String
  congregation_id String
  name            String
  type            FinancialCategoryType
  parent_id       String?
  description     String?
  is_system       Boolean               @default(false)
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  tenant       Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation        @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  parent       FinancialCategory?  @relation("CategoryHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children     FinancialCategory[] @relation("CategoryHierarchy")

  transactions FinancialTransaction[]
  pixPayments  PixPayment[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("financial_categories")
}

model CostCenter {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  name            String
  description     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  transactions FinancialTransaction[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("cost_centers")
}

model FinancialTransaction {
  id                 String            @id @default(uuid())
  tenant_id          String
  congregation_id    String
  type               TransactionType
  amount             Decimal           @db.Decimal(12, 2)
  occurred_at        DateTime
  description        String?
  category_id        String
  cost_center_id     String?
  donor_person_id    String?
  is_anonymous       Boolean           @default(false)
  source             TransactionSource
  status             TransactionStatus @default(pending)
  notes              String?
  recurring_rule_id  String?
  created_by_user_id String
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  tenant        Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation  Congregation      @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  category      FinancialCategory @relation(fields: [category_id], references: [id], onDelete: Restrict)
  costCenter    CostCenter?       @relation(fields: [cost_center_id], references: [id], onDelete: SetNull)
  donorPerson   Person?           @relation("TransactionDonor", fields: [donor_person_id], references: [id], onDelete: SetNull)
  recurringRule RecurringRule?    @relation(fields: [recurring_rule_id], references: [id], onDelete: SetNull)
  createdBy     UserAccount       @relation(fields: [created_by_user_id], references: [id], onDelete: Restrict)

  attachments      TransactionAttachment[]
  donationReceipts DonationReceipt[]
  pixPayment       PixPayment?

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, occurred_at])
  @@map("financial_transactions")
}

model TransactionAttachment {
  id                  String   @id @default(uuid())
  tenant_id           String
  transaction_id      String
  file_url            String
  file_name           String
  uploaded_by_user_id String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  transaction FinancialTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  uploadedBy  UserAccount          @relation(fields: [uploaded_by_user_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, transaction_id])
  @@map("transaction_attachments")
}

model RecurringRule {
  id                 String             @id @default(uuid())
  tenant_id          String
  congregation_id    String
  mode               RecurringRuleMode  @default(fixed)
  frequency          RecurringFrequency
  interval           Int                @default(1)
  installments       Int?
  next_occurrence_at DateTime
  ends_at            DateTime?
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  transactions FinancialTransaction[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("recurring_rules")
}

model PixPayment {
  id               String      @id @default(uuid())
  tenant_id        String
  congregation_id  String
  scenario         PixScenario
  transaction_id   String?     @unique
  asaas_payment_id String?
  amount           Decimal     @db.Decimal(12, 2)
  donor_person_id  String?
  category_id      String
  status           PixStatus
  pix_key          String?
  qr_code          String?
  paid_at          DateTime?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  tenant       Tenant                @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation          @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  transaction  FinancialTransaction? @relation(fields: [transaction_id], references: [id], onDelete: SetNull)
  donorPerson  Person?               @relation("PixDonor", fields: [donor_person_id], references: [id], onDelete: SetNull)
  category     FinancialCategory     @relation(fields: [category_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, status])
  @@map("pix_payments")
}

model DonationReceipt {
  id             String   @id @default(uuid())
  tenant_id      String
  transaction_id String
  person_id      String
  receipt_url    String
  generated_at   DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  transaction FinancialTransaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  person      Person               @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, transaction_id])
  @@index([person_id])
  @@map("donation_receipts")
}

// =============================================================================
// GRUPO 6 — CONTEÚDO
// =============================================================================

model ContentPost {
  id                 String          @id @default(uuid())
  tenant_id          String
  congregation_id    String
  type               ContentPostType
  title              String
  body               String?
  media_url          String?
  is_draft           Boolean         @default(true)
  publish_at         DateTime?
  published_at       DateTime?
  expires_at         DateTime?
  created_by_user_id String
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  createdBy    UserAccount  @relation(fields: [created_by_user_id], references: [id], onDelete: Restrict)

  audienceSegments       AudienceSegment[]
  postSegments           PostSegment[]
  notificationDispatches NotificationDispatch[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, published_at])
  @@map("content_posts")
}

model AudienceSegment {
  id              String               @id @default(uuid())
  tenant_id       String
  congregation_id String
  name            String
  criteria        Json
  // Legacy fields — nullable after migration to standalone
  content_post_id String?
  segment_type    AudienceSegmentType?
  segment_value   String?
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  tenant       Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation  @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  contentPost  ContentPost?  @relation(fields: [content_post_id], references: [id], onDelete: Cascade)
  postSegments PostSegment[]

  @@index([tenant_id, congregation_id])
  @@map("audience_segments")
}

model PostSegment {
  post_id    String
  segment_id String

  post    ContentPost     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  segment AudienceSegment @relation(fields: [segment_id], references: [id], onDelete: Cascade)

  @@id([post_id, segment_id])
  @@map("post_segments")
}

model NotificationDispatch {
  id              String              @id @default(uuid())
  tenant_id       String
  congregation_id String
  content_post_id String?
  channel         NotificationChannel
  status          NotificationStatus
  sent_at         DateTime?
  onesignal_id    String?
  reached         Int?
  opened          Int?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  contentPost  ContentPost? @relation(fields: [content_post_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, status])
  @@map("notification_dispatches")
}

// =============================================================================
// GRUPO 7 — VOLUNTARIADO E CELEBRAÇÕES
// =============================================================================

model Ministry {
  id                 String   @id @default(uuid())
  tenant_id          String
  congregation_id    String
  name               String
  description        String?
  color              String?
  parent_ministry_id String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  parent       Ministry?    @relation("MinistryHierarchy", fields: [parent_ministry_id], references: [id])
  children     Ministry[]   @relation("MinistryHierarchy")

  assignments         Assignment[]
  serviceOrderItems   ServiceOrderItem[]
  volunteerMinistries VolunteerMinistry[]
  serviceSchedules    ServiceSchedule[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([parent_ministry_id])
  @@map("ministries")
}

model VolunteerProfile {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  person_id       String   @unique
  availability    Json
  skills          Json
  restrictions    String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)

  volunteerMinistries      VolunteerMinistry[]
  scheduleAssignments      ScheduleAssignment[]
  swapRequestsAsRequester  VolunteerSwapRequest[] @relation("SwapRequester")
  swapRequestsAsSubstitute VolunteerSwapRequest[] @relation("SwapSubstitute")

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("volunteer_profiles")
}

model VolunteerMinistry {
  id                   String                @id @default(uuid())
  tenant_id            String
  congregation_id      String
  volunteer_profile_id String
  ministry_id          String
  role                 VolunteerMinistryRole @default(volunteer)
  is_primary_leader    Boolean               @default(false)
  created_at           DateTime              @default(now())

  volunteerProfile VolunteerProfile @relation(fields: [volunteer_profile_id], references: [id], onDelete: Cascade)
  ministry         Ministry         @relation(fields: [ministry_id], references: [id], onDelete: Cascade)
  tenant           Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation     Congregation     @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  @@unique([volunteer_profile_id, ministry_id])
  @@index([tenant_id, volunteer_profile_id])
  @@map("volunteer_ministries")
}

model ServiceSchedule {
  id                  String         @id @default(uuid())
  tenant_id           String
  congregation_id     String
  ministry_id         String
  title               String
  scheduled_date      DateTime
  deadline_confirm_at DateTime?
  status              ScheduleStatus @default(draft)
  created_by_user_id  String
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  ministry     Ministry     @relation(fields: [ministry_id], references: [id], onDelete: Cascade)

  slots ScheduleSlot[]

  @@index([tenant_id, ministry_id])
  @@index([tenant_id, scheduled_date])
  @@map("service_schedules")
}

model ScheduleSlot {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  schedule_id     String
  role_name       String
  required_count  Int      @default(1)
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  schedule     ServiceSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  tenant       Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation    @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  assignments ScheduleAssignment[]

  @@index([tenant_id, schedule_id])
  @@map("schedule_slots")
}

model ScheduleAssignment {
  id                   String           @id @default(uuid())
  tenant_id            String
  congregation_id      String
  slot_id              String
  volunteer_profile_id String
  status               AssignmentStatus @default(pending)
  checkin_token        String           @unique @default(uuid())
  confirmed_at         DateTime?
  checked_in_at        DateTime?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  slot             ScheduleSlot           @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  volunteerProfile VolunteerProfile       @relation(fields: [volunteer_profile_id], references: [id], onDelete: Cascade)
  tenant           Tenant                 @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation     Congregation           @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  swapRequests     VolunteerSwapRequest[]

  @@unique([slot_id, volunteer_profile_id])
  @@index([tenant_id, slot_id])
  @@index([checkin_token])
  @@map("schedule_assignments")
}

model VolunteerSwapRequest {
  id              String     @id @default(uuid())
  tenant_id       String
  congregation_id String
  assignment_id   String
  requester_id    String
  substitute_id   String?
  status          SwapStatus @default(pending)
  message         String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  assignment   ScheduleAssignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  requester    VolunteerProfile   @relation("SwapRequester", fields: [requester_id], references: [id])
  substitute   VolunteerProfile?  @relation("SwapSubstitute", fields: [substitute_id], references: [id])
  tenant       Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation       @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, assignment_id])
  @@map("volunteer_swap_requests")
}

model Assignment {
  id               String           @id @default(uuid())
  tenant_id        String
  congregation_id  String
  person_id        String
  ministry_id      String
  scheduled_date   DateTime
  role_in_ministry String
  status           AssignmentStatus
  confirmed_at     DateTime?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  person       Person       @relation(fields: [person_id], references: [id], onDelete: Cascade)
  ministry     Ministry     @relation(fields: [ministry_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@index([tenant_id, scheduled_date])
  @@map("assignments")
}

model Celebration {
  id              String                @id @default(uuid())
  tenant_id       String
  congregation_id String
  name            String
  type            CelebrationType
  day_of_week     Int?
  start_time      String
  recurrence      CelebrationRecurrence
  is_active       Boolean               @default(true)
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)

  instances CelebrationInstance[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("celebrations")
}

model CelebrationInstance {
  id                    String                    @id @default(uuid())
  tenant_id             String
  congregation_id       String
  celebration_id        String
  scheduled_date        DateTime
  status                CelebrationInstanceStatus @default(draft)
  notes                 String?
  host_reminder_sent_at DateTime?
  created_at            DateTime                  @default(now())
  updated_at            DateTime                  @updatedAt

  tenant       Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation  @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  celebration  Celebration   @relation(fields: [celebration_id], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder?

  @@index([tenant_id, celebration_id])
  @@index([tenant_id, scheduled_date])
  @@map("celebration_instances")
}

model ServiceOrder {
  id                      String    @id @default(uuid())
  tenant_id               String
  congregation_id         String
  celebration_instance_id String    @unique
  title                   String
  published_at            DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  tenant              Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation        Congregation        @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  celebrationInstance CelebrationInstance @relation(fields: [celebration_instance_id], references: [id], onDelete: Cascade)

  items ServiceOrderItem[]

  @@index([tenant_id, id])
  @@index([tenant_id, congregation_id])
  @@map("service_orders")
}

model ServiceOrderItem {
  id                   String          @id @default(uuid())
  tenant_id            String
  congregation_id      String
  service_order_id     String
  sequence             Int
  name                 String
  start_offset_minutes Int
  duration_minutes     Int
  responsible_type     ResponsibleType
  person_id            String?
  ministry_id          String?
  responsible_label    String?
  notes                String?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [service_order_id], references: [id], onDelete: Cascade)
  person       Person?      @relation(fields: [person_id], references: [id], onDelete: SetNull)
  ministry     Ministry?    @relation(fields: [ministry_id], references: [id], onDelete: SetNull)

  setlist Setlist?

  @@index([service_order_id])
  @@index([tenant_id, service_order_id])
  @@map("service_order_items")
}

model Setlist {
  id                    String   @id @default(uuid())
  tenant_id             String
  congregation_id       String
  service_order_item_id String   @unique
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation     Congregation     @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  serviceOrderItem ServiceOrderItem @relation(fields: [service_order_item_id], references: [id], onDelete: Cascade)

  songs SetlistSong[]

  @@index([tenant_id, congregation_id])
  @@map("setlists")
}

model SetlistSong {
  id              String   @id @default(uuid())
  tenant_id       String
  congregation_id String
  setlist_id      String
  sequence        Int
  title           String
  key             String?
  bpm             Int?
  link            String?
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  congregation Congregation @relation(fields: [congregation_id], references: [id], onDelete: Cascade)
  setlist      Setlist      @relation(fields: [setlist_id], references: [id], onDelete: Cascade)

  @@index([setlist_id])
  @@index([tenant_id, setlist_id])
  @@map("setlist_songs")
}

// =============================================================================
// GRUPO 8 — AUDITORIA
// =============================================================================

/// Tabela append-only — sem updated_at por design
/// congregation_id é UUID histórico bruto, sem FK: preserva rastreabilidade mesmo após deleção da congregação
model AuditLog {
  id                String   @id @default(uuid())
  tenant_id         String
  congregation_id   String?
  actor_user_id     String
  subject_person_id String?
  entity            String
  action            String
  before            Json?
  after             Json?
  ip                String?
  user_agent        String?
  at                DateTime @default(now())

  tenant    Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  actorUser UserAccount @relation("AuditActorUser", fields: [actor_user_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, at])
  @@index([tenant_id, congregation_id])
  @@index([actor_user_id])
  @@index([subject_person_id])
  @@index([entity, action])
  @@map("audit_logs")
}

