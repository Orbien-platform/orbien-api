  leaders_only
}

// --- Financeiro ---

enum FinancialCategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
}

enum TransactionSource {
  manual
  pix_webhook
  recurring
}

enum TransactionStatus {
